# ──────────────────────────────────────────────
def get_expected_co2(plant_type, hour):
    """현재 시각 기준 이 식물의 예상 CO2 계산"""
    profile = PLANT_PROFILES.get(plant_type, PLANT_PROFILES["C3"])
    offset  = profile["hourly_co2_offset"][hour]
    return CO2_BASE + offset

def update_light_status(co2_val, plant_type, co2_level):
    """
    예상 CO2 vs 실제 CO2 비교 후 보조광 ON/OFF 결정
    
    판단 기준:
    - 위험/주의 → 경고 우선 (보조광 X)
    - 실제 CO2 > 예상 CO2 + THRESHOLD → 광합성 부족 → 보조광 ON
    - 실제 CO2 <= 예상 CO2 + THRESHOLD → 정상 → 보조광 OFF
    """
    hour     = get_current_hour()
    expected = get_expected_co2(plant_type, hour)
    diff     = co2_val - expected   # 양수 = 실제가 더 높음 (광합성 부족)

    NP_STATE["expected_co2"] = expected
    NP_STATE["diff"]         = diff

    # 위험/주의 최우선
    if co2_level == "danger":
        NP_STATE["mode"]        = "danger"
        NP_STATE["light_on"]    = False
        NP_STATE["light_reason"] = "CO2 위험 — 환기 필요!"
        return

    if co2_level == "caution":
        NP_STATE["mode"]        = "caution"
        NP_STATE["light_on"]    = False
        NP_STATE["light_reason"] = "CO2 주의 — 환기 권장"
        return

    # CAM 식물 특별 처리
    if plant_type == "CAM":
        if hour >= 20 or hour < 6:
            # CAM 야간 → 기공 열림 → CO2 흡수 중
            if diff > LIGHT_THRESHOLD:
                # 흡수가 안 되고 있음 — 보조광 의미 없음
                # (CAM은 빛이 아니라 어둠에서 흡수)
                NP_STATE["mode"]        = "cam_night"
                NP_STATE["light_on"]    = False
                NP_STATE["light_reason"] = (
                    "CAM 야간 — CO2 흡수 부족 ({:.0f}ppm 초과)".format(diff)
                    + " / 빛 대신 환기 확인!"
                )
            else:
                NP_STATE["mode"]        = "cam_night"
                NP_STATE["light_on"]    = False
                NP_STATE["light_reason"] = "CAM 야간 흡수 정상 ({:+.0f}ppm)".format(-diff)
        else:
            # CAM 주간 → 기공 닫힘 → CO2 증가 정상
            NP_STATE["mode"]        = "cam_day"
            NP_STATE["light_on"]    = False
            NP_STATE["light_reason"] = "CAM 주간 — 기공 닫힘 정상"
        return

    # C3 / C4 식물
    if diff > LIGHT_THRESHOLD:
        # 실제 CO2 > 예상 CO2  → 광합성 부족 → 보조광 ON!
        NP_STATE["mode"]        = "light_assist"
        NP_STATE["light_on"]    = True
        NP_STATE["light_reason"] = (
            "광합성 부족! 예상 {:.0f}ppm / 실제 {:.0f}ppm "
            "(+{:.0f}ppm 초과) → 보조광 공급"
        ).format(expected, co2_val, diff)
    else:
        # 정상 범위
        NP_STATE["mode"]        = "good"
        NP_STATE["light_on"]    = False
        NP_STATE["light_reason"] = (
            "광합성 정상! 예상 {:.0f}ppm / 실제 {:.0f}ppm "
            "({:+.0f}ppm)"
        ).format(expected, co2_val, diff)


