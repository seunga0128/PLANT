                    state["temp"]   = temp
                    state["humi"]   = humi
                    state["level"]  = classify_co2(co2)
            except Exception as e:
                print("[Sensor] 에러:", e)
        else:
            if ptype:
                dummy          = gen_dummy_co2(ptype, hour)
                state["co2"]   = dummy
                state["temp"]  = 22.0
                state["humi"]  = 55.0
                state["level"] = classify_co2(dummy)

        if ptype and state["co2"] > 0:
            h = state["co2_history"]
            t = state["ts"]
            h.append(round(state["co2"], 1))
            t.append(get_time_str())
            if len(h) > GRAPH_MAX_POINTS:
                h.pop(0); t.pop(0)

            # 보조광 판단
            update_light_status(state["co2"], ptype, state["level"])

            if NP_STATE["light_on"]:
                print("[LED] 보조광 ON | 예상:{:.0f} 실제:{:.0f} 차이:{:+.0f}".format(
                    NP_STATE["expected_co2"],
                    state["co2"],
                    NP_STATE["diff"]
                ))

        if time.ticks_diff(now_tick, last_sheet_tick) >= SHEET_LOG_INTERVAL * 1000:
            last_sheet_tick = now_tick
            if ptype and state["co2"] > 0:
                send_to_sheet(
                    state["co2"], state["temp"], state["humi"], ptype,
                    NP_STATE["expected_co2"],
                    NP_STATE["diff"],
                    NP_STATE["light_on"]
                )

    try:
        conn, addr = server.accept()
        conn.setblocking(True)
        try:
            raw = conn.recv(1024).decode("utf-8", "ignore")
            if not raw:
                conn.close()
                continue
            first = raw.split("\r\n")[0]
            parts = first.split(" ")
            path  = parts[1] if len(parts) > 1 else "/"

            if path == "/" or path == "/index.html":
                if not state["plant_type"]:
                    conn.sendall(
                        b"HTTP/1.1 302 Found\r\n"
                        b"Location: /setup\r\n"
                        b"Connection: close\r\n\r\n"
                    )
                else:
                    send_response(conn, "200 OK", "text/html",
                                  build_dashboard_html())
            elif path == "/setup":
                send_response(conn, "200 OK", "text/html", SETUP_PAGE)
            elif path.startswith("/set_plant"):
                ptype_new = "C3"
                if "type=" in path:
                    ptype_new = path.split("type=")[1].split("&")[0].upper()
                if ptype_new in PLANT_PROFILES:
                    state["plant_type"]   = ptype_new
                    state["co2_history"]  = []
                    state["ts"]           = []
                    state["elapsed_min"]  = 0
                    start_tick            = time.ticks_ms()
                    np_off()
                    print("[Setup] 식물 설정:", ptype_new)
                send_response(conn, "200 OK", "application/json",
                              json.dumps({"ok": True, "plant": ptype_new}))
            elif path == "/data":
                send_response(conn, "200 OK", "application/json", make_json())
            else:
                send_response(conn, "404 Not Found", "text/plain", "Not Found")

        except Exception as e:
            print("[HTTP] 처리 에러:", e)
        finally:
            conn.close()

    except OSError:
        pass

    time.sleep_ms(10)
