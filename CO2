def https_get(url):
    host, _, path = url[8:].partition("/")
    gc.collect()
    raw_sock = socket.socket()
    try:
        raw_sock.connect(socket.getaddrinfo(host, 443)[0][-1])
        try:
            ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_CLIENT)
            ctx.verify_mode = ssl.CERT_NONE
            sock = ctx.wrap_socket(raw_sock, server_hostname=host)
        except AttributeError:
            sock = ssl.wrap_socket(raw_sock, server_hostname=host)
        sock.write((
            "GET /{} HTTP/1.0\r\n"
            "Host: {}\r\n"
            "User-Agent: Pico2W\r\n"
            "Connection: close\r\n\r\n"
        ).format(path, host).encode("utf-8"))
        buf = b""
        while True:
            chunk = sock.read(512)
            if not chunk: break
            buf += chunk
            if b"\r\n\r\n" in buf: break
        return buf
    finally:
        try: raw_sock.close()
        except: pass

def send_to_sheet(co2, temp, humi, plant_type, expected, diff, light_on):
    url = (
        GOOGLE_SHEET_URL
        + "?co2="      + "{:.1f}".format(co2)
        + "&temp="     + "{:.1f}".format(temp)
        + "&humi="     + "{:.1f}".format(humi)
        + "&plant="    + plant_type
        + "&expected=" + "{:.1f}".format(expected)
        + "&diff="     + "{:.1f}".format(diff)
        + "&light="    + ("ON" if light_on else "OFF")
    )
    print("[Sheet] CO2={:.0f} 예상={:.0f} 차이={:+.0f} 보조광={}".format(
        co2, expected, diff, "ON" if light_on else "OFF"))
    try:
        resp = https_get(url)
        head = resp.split(b"\r\n\r\n", 1)[0]
        if b" 302 " in head or b" 301 " in head:
            for line in head.split(b"\r\n"):
                if line.lower().startswith(b"location:"):
                    redirect_url = line.split(b":", 1)[1].strip().decode()
                    https_get(redirect_url)
                    break
        print("[Sheet] 전송 완료")
    except Exception as e:
        print("[Sheet] 실패:", e)


