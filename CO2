SENSOR_INTERVAL  = 2000
last_sensor_tick = time.ticks_ms()

while True:
    now_tick = time.ticks_ms()

    apply_np_state(state["co2"])

    if time.ticks_diff(now_tick, last_sensor_tick) >= SENSOR_INTERVAL:
        last_sensor_tick     = now_tick
