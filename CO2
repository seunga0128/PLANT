function highlightHour(h){
  for(var i=0;i<24;i++){
    var bar=document.getElementById('hbar-'+i);
    if(!bar)continue;
    bar.style.outline=i===h?'2px solid #fff':'none';
    bar.style.zIndex =i===h?'10':'1';
    bar.style.position='relative';
  }
}

function fetchData(){
  fetch('/data')
    .then(function(r){return r.json();})
    .then(function(d){
      // 측정값
      document.getElementById('v-co2').textContent =d.co2.toFixed(1);
      document.getElementById('v-temp').textContent=d.temp.toFixed(1);
      document.getElementById('v-humi').textContent=d.humi.toFixed(1);
      var st=STATUS[d.level]||STATUS.safe;
      document.getElementById('v-icon').textContent=st.icon;
      var b=document.getElementById('v-badge');
      b.textContent=st.text; b.className='badge '+st.cls;

      // 보조광 패널
      var panel=document.getElementById('light-panel');
      var on=d.light_on||false;
      panel.className='light-panel '+(on?'on':'off');
      document.getElementById('lp-icon').textContent=on?'💡':'⭕';
      document.getElementById('lp-title').textContent=
        on?'💡 보조광 ON — 광합성 보조 중!':'보조광 OFF';
      document.getElementById('lp-title').style.color=
        on?'#fffccc':'#e2e8f0';
      document.getElementById('lp-sub').textContent=d.light_reason||'';
      document.getElementById('lp-time').textContent=d.current_time||'--';

      var exp=d.expected_co2||0;
      var act=d.co2||0;
      var diff=d.diff||0;
      document.getElementById('lp-expected').textContent=exp.toFixed(0);
      document.getElementById('lp-actual').textContent  =act.toFixed(0);
      document.getElementById('lp-diff').textContent    =
        (diff>0?'+':'')+diff.toFixed(0);
      document.getElementById('lp-diff').style.color=
        diff>LIGHT_THRESH?'#ef4444':(diff<-LIGHT_THRESH?'#22c55e':'#f59e0b');

      // 차이 바
      var pct=Math.min(Math.abs(diff)/300*100,100);
      var dbar=document.getElementById('diff-bar');
      dbar.style.width=pct+'%';
      dbar.style.background=diff>LIGHT_THRESH?'#ef4444':
                             (diff<-LIGHT_THRESH?'#22c55e':'#f59e0b');

      // 그래프 (실측 + 예상)
      var hist=d.history||[];
      var ts=d.ts||[];
      var exp_hist=d.expected_history||[];
      chart.data.labels=ts;
      chart.data.datasets[0].data=hist;
      chart.data.datasets[1].data=exp_hist;
      if(hist.length>0){
        var all=hist.concat(exp_hist).filter(function(v){return v!=null;});
        var mn=Math.min.apply(null,all);
        var mx=Math.max.apply(null,all);
        var pad=Math.max(mx-mn,50)*0.2;
        chart.options.scales.y.min=Math.max(0,Math.floor(mn-pad));
        chart.options.scales.y.max=Math.ceil(mx+pad);
      }
      chart.update();

      // LED
      updateStrip(d.np_mode||'idle',d.co2);

      // 현재 시각 바 강조
      highlightHour(d.current_hour||0);

      // 구글 시트
      var ss=document.getElementById('sheet-status');
      ss.textContent=d.last_sheet_sent!==undefined
        ?d.last_sheet_sent+'초 전':'대기';

      document.getElementById('footer').textContent=
        '갱신: '+new Date().toLocaleTimeString('ko-KR')+
        ' · 가동 '+d.uptime+'초';
    })
    .catch(function(e){console.warn(e);});
}
fetchData();
setInterval(fetchData,2000);

function runSim(){
  var light=+document.getElementById('s-light').value;
  var temp =+document.getElementById('s-temp').value;
  var water=+document.getElementById('s-water').value;
  var count=+document.getElementById('s-count').value;
  document.getElementById('sv-light').textContent=light+'%';
  document.getElementById('sv-temp').textContent =temp+'C';
  document.getElementById('sv-water').textContent=water+'%';
  document.getElementById('sv-count').textContent=count+'그루';
  var abs=0;
  if(PLANT_TYPE==='CAM'){
    abs=(water/100)*0.6*count-(light/100)*0.4;
    if(temp>35)abs*=1.1;
  }else if(PLANT_TYPE==='C4'){
    var tf=temp>=25&&temp<=40?1.2:(temp<15?0.4:0.8);
    abs=(light/100)*tf*(water/100)*1.5*count;
  }else{
    var tf=temp>=15&&temp<=28?1.0:(temp>35?0.3:0.6);
    abs=(light/100)*tf*(water/100)*count;
  }
  var delta=-(abs*60);
  var dir=delta<0?'감소(흡수)':'증가(배출)';
  var mag=Math.abs(delta);
  var tips=[];
  if(PLANT_TYPE==='CAM'){
    if(light>70)tips.push('CAM은 강한 빛에서 기공 닫아 흡수 감소');
    if(water<30)tips.push('수분 부족시 야간 흡수도 감소');
  }else if(PLANT_TYPE==='C4'){
    if(temp<15)tips.push('C4는 저온에서 효율 급감');
    if(light<30)tips.push('빛 부족시 흡수량 급감');
