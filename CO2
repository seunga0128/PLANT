NUM_PIXELS = 60
np = NeoPixel(Pin(16), NUM_PIXELS)

def np_off():
    for i in range(NUM_PIXELS):
        np[i] = (0, 0, 0)
    np.write()

def np_fill(r, g, b):
    for i in range(NUM_PIXELS):
        np[i] = (r, g, b)
    np.write()

def np_progress(ratio):
    count = int(ratio * NUM_PIXELS)
    for i in range(NUM_PIXELS):
        if i < count:
            if ratio < 0.5:
                r = int(ratio * 2 * 255)
                g = 200
            else:
                r = 200
                g = int((1.0 - (ratio - 0.5) * 2) * 200)
            np[i] = (r, g, 0)
        else:
            np[i] = (0, 0, 0)
    np.write()

NP_STATE = {
    "mode":         "idle",
    "blink_tick":   0,
    "blink_on":     False,
    "light_on":     False,
    "light_reason": "",
    "expected_co2": 0.0,
    "diff":         0.0,
}

def apply_np_state(co2_val):
    mode = NP_STATE["mode"]
    now  = time.ticks_ms()

    if mode == "danger":
        if time.ticks_diff(now, NP_STATE["blink_tick"]) >= 300:
            NP_STATE["blink_tick"] = now
            NP_STATE["blink_on"]   = not NP_STATE["blink_on"]
        if NP_STATE["blink_on"]: np_fill(150, 0, 0)
        else:                    np_off()

    elif mode == "caution":
        if time.ticks_diff(now, NP_STATE["blink_tick"]) >= 1000:
            NP_STATE["blink_tick"] = now
            NP_STATE["blink_on"]   = not NP_STATE["blink_on"]
        if NP_STATE["blink_on"]: np_fill(80, 50, 0)
        else:                    np_off()

    elif mode == "light_assist":
        # 보조광 — 밝은 흰색
        np_fill(220, 220, 190)

    elif mode == "good":
        # 광합성 잘 됨 — 초록 게이지
        MIN_CO2 = 400; MAX_CO2 = 2000
        ratio = min(max((co2_val - MIN_CO2) / (MAX_CO2 - MIN_CO2), 0.0), 1.0)
        np_progress(ratio)

    elif mode == "cam_night":
        np_fill(0, 0, 100)   # 파랑 — CAM 야간 흡수

    elif mode == "cam_day":
        np_fill(60, 40, 0)   # 어두운 노랑 — CAM 주간 대기

    else:
        np_fill(0, 0, 15)


