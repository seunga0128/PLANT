board_led = Pin("LED", Pin.OUT)
rtc       = RTC()

def connect_wifi():
    wlan = network.WLAN(network.STA_IF)
    wlan.active(False)
    time.sleep(0.5)
    wlan.active(True)
    time.sleep(0.5)

    if wlan.isconnected():
        print("[WiFi] 이미 연결됨:", wlan.ifconfig()[0])
        board_led.on()
        return wlan.ifconfig()[0]

    print("[WiFi] 연결 중:", WIFI_SSID)
    wlan.connect(WIFI_SSID, WIFI_PASSWORD)
    timeout = 20
    while not wlan.isconnected() and timeout > 0:
        board_led.toggle()
        time.sleep(0.5)
        timeout -= 1

    if wlan.isconnected():
        ip = wlan.ifconfig()[0]
        print("[WiFi] 연결 성공! IP:", ip)
        board_led.on()
        return ip
    else:
        print("[WiFi] 연결 실패 상태코드:", wlan.status())
        board_led.off()
        return "0.0.0.0"

def sync_ntp():
    """인터넷에서 현재 시각을 받아와서 RTC에 설정"""
    try:
        ntptime.host = "pool.ntp.org"
        ntptime.settime()   # UTC 기준으로 설정됨
        # 한국 시간 = UTC + 9시간
        t   = utime.localtime(utime.mktime(utime.localtime()) + 9 * 3600)
        rtc.datetime((t[0], t[1], t[2], t[6], t[3], t[4], t[5], 0))
        print("[NTP] 시간 동기화 완료: {:04d}-{:02d}-{:02d} {:02d}:{:02d}:{:02d}".format(
            t[0], t[1], t[2], t[3], t[4], t[5]))
        return True
    except Exception as e:
        print("[NTP] 실패:", e)
        return False

def get_current_hour():
    """현재 시각의 시(hour) 반환 (0~23)"""
    dt = rtc.datetime()
    return dt[4]   # (year, month, day, weekday, hour, min, sec, subsec)

def get_time_str():
    dt = rtc.datetime()
    return "{:02d}:{:02d}:{:02d}".format(dt[4], dt[5], dt[6])


