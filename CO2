     borderColor:'#a78bfa',borderDash:[5,4],
     borderWidth:2,pointRadius:0,tension:0.3,fill:false}
  ]},
  options:{
    responsive:true,maintainAspectRatio:false,animation:{duration:250},
    interaction:{mode:'index',intersect:false},
    scales:{
      x:{ticks:{color:'#8892a4',maxTicksLimit:10},grid:{color:'#2e3148'}},
      y:{ticks:{color:'#8892a4'},grid:{color:'#2e3148'}}
    },
    plugins:{
      legend:{labels:{color:'#e2e8f0',font:{size:11}}},
      tooltip:{callbacks:{label:function(c){
        return ' '+c.dataset.label+': '+
          (c.parsed.y!=null?c.parsed.y.toFixed(1):'')+'ppm';
      }}}
    }
  }
});

var STATUS={
  safe:    {icon:'😊',text:'쾌적',          cls:'safe'},
  caution: {icon:'😐',text:'주의 환기권장', cls:'caution'},
  danger:  {icon:'🚨',text:'위험 창문열기', cls:'danger'}
};

var blinkTimer=null,blinkOn=false;

function stripSetAll(r,g,b){
  var c='#'+('0'+Math.round(r).toString(16)).slice(-2)
           +('0'+Math.round(g).toString(16)).slice(-2)
           +('0'+Math.round(b).toString(16)).slice(-2);
  for(var i=0;i<NUM_PIXELS;i++)
    document.getElementById('seg-'+i).style.background=c;
}
function stripOff(){
  for(var i=0;i<NUM_PIXELS;i++)
    document.getElementById('seg-'+i).style.background='#0a0a0a';
}
function stripProgress(ratio){
  var count=Math.floor(ratio*NUM_PIXELS);
  for(var i=0;i<NUM_PIXELS;i++){
    var seg=document.getElementById('seg-'+i);
    if(i<count){
      var r,g;
      if(ratio<0.5){r=ratio*2*255;g=200;}
      else{r=200;g=(1-(ratio-0.5)*2)*200;}
      seg.style.background='rgb('+Math.round(r)+','+Math.round(g)+',0)';
    } else seg.style.background='#0a0a0a';
  }
}
function updateStrip(mode,co2){
  if(blinkTimer){clearInterval(blinkTimer);blinkTimer=null;}
  if(mode==='light_assist'){
    stripSetAll(220,220,190);
  } else if(mode==='good'){
    var ratio=Math.min(Math.max((co2-400)/1600,0),1);
    stripProgress(ratio);
  } else if(mode==='cam_night'){
    stripSetAll(0,0,100);
  } else if(mode==='cam_day'){
    stripSetAll(60,40,0);
  } else if(mode==='caution'){
    blinkTimer=setInterval(function(){
      blinkOn=!blinkOn;
      if(blinkOn)stripSetAll(80,50,0);else stripOff();
    },1000);
  } else if(mode==='danger'){
    blinkTimer=setInterval(function(){
      blinkOn=!blinkOn;
      if(blinkOn)stripSetAll(150,0,0);else stripOff();
    },300);
  } else stripSetAll(0,0,15);
}

